APP_NAME=Energy Monitoring API
ENVIRONMENT=development
SECRET_KEY=change-this-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database separation ──────────────────────────────────────────────────────
# App/auth/RBAC database — Alembic runs migrations here ONLY.
# Create with: psql -U postgres -c "CREATE DATABASE energy_app_db"
DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/energy_app_db

# Telemetry/monitoring database — NEVER pass this to Alembic.
# Leave commented out if you don't have a local monitoring DB.
# MONITORING_DATABASE_URL=postgresql+psycopg2://postgres:password@127.0.0.1:5432/Kalleh_Amol_DB
